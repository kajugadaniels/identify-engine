# ─── App ─────────────────────────────────────────────
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000

# ─── Internal security ───────────────────────────────
INTERNAL_API_KEY=

# ─── AWS credentials ─────────────────────────────────
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1

# ─── Scoring thresholds ───────────────────────────────
LIVENESS_THRESHOLD=80.0
FACE_MATCH_THRESHOLD=85.0
COMPOSITE_PASS_THRESHOLD=80.0

# ─── Score weights (must add up to 1.0) ───────────────
LIVENESS_WEIGHT=0.35
FACE_MATCH_WEIGHT=0.50
OCR_WEIGHT=0.15